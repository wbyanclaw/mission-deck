{
  "id": "mission-deck",
  "name": "MISSION DECK",
  "description": "Configuration-driven multi-agent orchestration guardrails with TaskFlow-aware delegation tracing and dashboard outputs.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabledAgents": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "coordinatorAgentId": {
        "type": "string"
      },
      "codeExecutorAgentIds": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "internalFirst": {
        "type": "boolean"
      },
      "interventionIdleMinutes": {
        "type": "integer",
        "minimum": 1
      },
      "blockPrematureUserEscalation": {
        "type": "boolean"
      },
      "blockPrematureSpawn": {
        "type": "boolean"
      },
      "blockInvalidSessionsSend": {
        "type": "boolean"
      },
      "redactDashboardContent": {
        "type": "boolean"
      },
      "redactSessionKeys": {
        "type": "boolean"
      },
      "redactPromptMetadata": {
        "type": "boolean"
      },
      "taskKeywords": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "agentWorkspaceRoots": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "entrypointPatterns": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "discoveryToolNames": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "dashboardRetentionDays": {
        "type": "integer",
        "minimum": 1
      },
      "dashboardStatusPath": {
        "type": "string"
      },
      "dashboardDataDir": {
        "type": "string"
      },
      "taskflowSupervisor": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "agentId": {
            "type": "string"
          },
          "intervalMinutes": {
            "type": "integer",
            "minimum": 1
          },
          "maxConcurrent": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "dashboardHttp": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "host": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
